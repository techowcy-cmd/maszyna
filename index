  },
  {
    id:'studio', name:'Studio Room', type:'studio', category:'natural',
    icon:'🎛', desc:'Kabina nagraniowa — suchy, kontrolowany, pro studio.',
    decayMult:0.9, preDelayMult:0.4, diffMult:0.55,
    color:'#4db6ac',
    knobs:{ density:0.50, wet:0.18, diff:0.55 },
    decayRange:[100,500], preDelayRange:[2,8],
    note:'Najmniejszy rozmiar. Dead room feel. Tight mix.',
  },
  {
    id:'arena', name:'Arena / Stadium', type:'arena', category:'natural',
    icon:'🏟', desc:'Arena / stadion — masywna, żywa przestrzeń na tłum.',
    decayMult:6.0, preDelayMult:2.0, diffMult:0.75,
    color:'#ef9a9a',
    knobs:{ density:0.70, wet:0.40, diff:0.72 },
    decayRange:[3000,10000], preDelayRange:[30,90],
    note:'T60: 3–10s. Echo od ścian, duży pre-delay. Live feel.',
  },
];

// ─── STATE ────────────────────────────────────────────────────────────────────
let state = {
  bpm: 120,
  noteId: '1/4',
  view: 'all',
};

let tapTimes = [];
let tapTimeout = null;

// ─── CALCULATIONS ─────────────────────────────────────────────────────────────
function beatMs(bpm) { return 60000 / bpm; }

function noteMs(bpm, noteId) {
  const note = NOTES.find(n => n.id === noteId);
  const beat = beatMs(bpm);
  return (beat * 4) / note.div;
}

function calcReverb(bpm, reverb) {
  const beat = beatMs(bpm);
  const selNote = NOTES.find(n => n.id === state.noteId);
  const baseMs = (beat * 4) / selNote.div;

  // Decay = wielokrotność bazowego czasu
  const decay = Math.round(baseMs * reverb.decayMult);
  const clamped_decay = Math.min(Math.max(decay, reverb.decayRange[0]), reverb.decayRange[1]);

  // Pre-delay = proporcja do ćwiartki
  const preDel = Math.round(beat * reverb.preDelayMult / 4);
  const clamped_pre = Math.min(Math.max(preDel, reverb.preDelayRange[0]), reverb.preDelayRange[1]);

  // Wartości dla każdej nuty
  const noteVals = NOTES.map(note => {
    const ms = (beat * 4) / note.div;
    return { ...note, ms: Math.round(ms) };
  });

  return { decay: clamped_decay, preDelay: clamped_pre, noteVals, baseMs: Math.round(baseMs), beat: Math.round(beat) };
}

// ─── UI HELPERS ───────────────────────────────────────────────────────────────
function msFormat(ms) {
  if (ms >= 1000) return (ms/1000).toFixed(2) + 's';
  return ms + 'ms';
}

function drawDecayBars(containerId, decay, color) {
  const el = document.getElementById(containerId);
  if (!el) return;
  const maxDecay = 20000;
  const ratio = Math.min(decay / maxDecay, 1);
  const bars = el.querySelectorAll('.decay-bar');
  bars.forEach((bar, i) => {
    const t = i / (bars.length - 1);
    const h = ratio * Math.exp(-t * 3.5) * 28 + 2;
    bar.style.height = Math.round(h) + 'px';
    bar.style.opacity = 0.3 + (1 - t) * 0.7;
  });
}

function flashUpdate(el) {
  el.classList.remove('updated');
  void el.offsetWidth;
  el.classList.add('updated');
  setTimeout(() => el.classList.remove('updated'), 200);
}

// ─── RENDER NOTES ─────────────────────────────────────────────────────────────
function renderNoteGrid() {
  const grid = document.getElementById('noteGrid');
  grid.innerHTML = '';
  NOTES.forEach(note => {
    const btn = document.createElement('button');
    btn.className = 'note-btn' + (note.id === state.noteId ? ' selected' : '');
    btn.textContent = note.label;
    btn.title = note.name;
    btn.onclick = () => { state.noteId = note.id; renderAll(); };
    grid.appendChild(btn);
  });
}

// ─── RENDER REVERB CARDS ──────────────────────────────────────────────────────
function renderReverbGrid() {
  const grid = document.getElementById('reverbGrid');
  const visible = REVERB_TYPES.filter(r =>
    state.view === 'all' ||
    (state.view === 'natural' && r.category === 'natural') ||
    (state.view === 'synthetic' && r.category === 'synthetic')
  );

  grid.innerHTML = '';
  visible.forEach((rev, idx) => {
    const calc = calcReverb(state.bpm, rev);

    const card = document.createElement('div');
    card.className = `reverb-card t-${rev.type}` + (rev.featured ? ' featured' : '');
    card.style.animationDelay = (idx * 0.05) + 's';

    // Decay bars
    const barCount = 32;
    const bars = Array.from({length: barCount}, () =>
      `<div class="decay-bar" style="height:2px;"></div>`
    ).join('');

    // Sub-value chips (all notes)
    const chipHTML = NOTES.map(note => {
      const ms = Math.round((calc.beat * 4) / note.div);
      const isSelected = note.id === state.noteId;
      return `<div class="sub-val-chip ${isSelected ? 'selected-note' : ''}">
        <span class="chip-note">${note.label}</span>
        ${ms < 1000 ? ms + 'ms' : (ms/1000).toFixed(2)+'s'}
      </div>`;
    }).join('');

    card.innerHTML = `
      <div class="card-header">
        <div>
          <div class="card-type-badge">${rev.category === 'natural' ? 'NATURALNE' : 'SYNTETYCZNE'}</div>
          <div class="card-name">${rev.name}</div>
          <div class="card-desc">${rev.desc}</div>
        </div>
        <div class="card-icon">${rev.icon}</div>
      </div>
      <div class="decay-visual" id="dv_${rev.id}">${bars}</div>
      <div class="card-body">
        <div class="val-row">
          <div class="val-label">
            <div class="val-dot"></div>Pre-Delay
          </div>
          <div class="val-numbers">
            <span class="val-main" id="pd_${rev.id}">${calc.preDelay}</span>
            <span class="val-unit">ms</span>
          </div>
        </div>
        <div class="val-row">
          <div class="val-label">
            <div class="val-dot"></div>Decay (RT60)
          </div>
          <div class="val-numbers">
            <span class="val-main" id="dc_${rev.id}">${msFormat(calc.decay)}</span>
          </div>
        </div>
        <div class="val-row">
          <div class="val-label">
            <div class="val-dot"></div>Zakres Pre-Del
          </div>
          <div class="val-numbers">
            <span class="val-main" style="font-size:14px;">${rev.preDelayRange[0]}–${rev.preDelayRange[1]}</span>
            <span class="val-unit">ms</span>
          </div>
        </div>
        <div class="val-row">
          <div class="val-label">
            <div class="val-dot"></div>Zakres Decay
          </div>
          <div class="val-numbers">
            <span class="val-main" style="font-size:14px;">${msFormat(rev.decayRange[0])}–${msFormat(rev.decayRange[1])}</span>
          </div>
        </div>
        <div class="sub-vals" id="sv_${rev.id}">
          ${chipHTML}
        </div>
        <div style="margin-top:10px; font-family:'Barlow Condensed',sans-serif; font-size:11px; color:var(--text3); letter-spacing:0.5px; line-height:1.5; padding-top:8px; border-top:1px solid rgba(42,48,80,0.4);">
          ${rev.note}
        </div>
      </div>
    `;
    grid.appendChild(card);

    requestAnimationFrame(() => drawDecayBars('dv_' + rev.id, calc.decay, rev.color));
  });
}

// ─── UPDATE VALUES (without re-render) ───────────────────────────────────────
function updateValues() {
  const beat = beatMs(state.bpm);
  document.getElementById('quarterTime').textContent = Math.round(beat);
  document.getElementById('periodDisplay').textContent = (1 / (state.bpm / 60)).toFixed(3) + 's';
  document.getElementById('freqDisplay').textContent = (state.bpm / 60).toFixed(3) + ' Hz';

  // Status bar
  document.getElementById('sbBpm').textContent = state.bpm;
  document.getElementById('sbBeat').textContent = Math.round(beat) + 'ms';
  document.getElementById('sb8th').textContent = Math.round(beat/2) + 'ms';
  document.getElementById('sb16th').textContent = Math.round(beat/4) + 'ms';

  const visibleTypes = REVERB_TYPES.filter(r =>
    state.view === 'all' ||
    (state.view === 'natural' && r.category === 'natural') ||
    (state.view === 'synthetic' && r.category === 'synthetic')
  );

  if (visibleTypes.length > 0) {
    const first = calcReverb(state.bpm, visibleTypes[0]);
    document.getElementById('sbDecay').textContent = msFormat(first.decay);
  }

  // Update each card
  visibleTypes.forEach(rev => {
    const calc = calcReverb(state.bpm, rev);
    const pdEl = document.getElementById('pd_' + rev.id);
    const dcEl = document.getElementById('dc_' + rev.id);
    const svEl = document.getElementById('sv_' + rev.id);
    if (!pdEl) return;
    if (pdEl.textContent !== String(calc.preDelay)) {
      pdEl.textContent = calc.preDelay;
      flashUpdate(pdEl);
    }
    if (dcEl.textContent !== msFormat(calc.decay)) {
      dcEl.textContent = msFormat(calc.decay);
      flashUpdate(dcEl);
    }
    drawDecayBars('dv_' + rev.id, calc.decay, rev.color);

    // Update chips
    if (svEl) {
      const chips = svEl.querySelectorAll('.sub-val-chip');
      chips.forEach((chip, i) => {
        const note = NOTES[i];
        const ms = Math.round((calc.beat * 4) / note.div);
        chip.innerHTML = `<span class="chip-note">${note.label}</span>${ms < 1000 ? ms + 'ms' : (ms/1000).toFixed(2)+'s'}`;
        chip.className = 'sub-val-chip' + (note.id === state.noteId ? ' selected-note' : '');
      });
    }
  });
}

function renderAll() {
  // Update BPM display
  document.getElementById('bpmDisplay').textContent = state.bpm;
  document.getElementById('bpmInput').value = state.bpm;
  document.getElementById('bpmSlider').value = state.bpm;

  // Update quick buttons
  document.querySelectorAll('.bpm-btn').forEach(btn => {
    btn.classList.toggle('active', parseInt(btn.dataset.bpm) === state.bpm);
  });

  // Update note grid
  document.querySelectorAll('.note-btn').forEach((btn, i) => {
    btn.classList.toggle('selected', NOTES[i].id === state.noteId);
  });

  updateValues();
}

// ─── EVENTS ───────────────────────────────────────────────────────────────────
function setBpm(v) {
  v = Math.max(20, Math.min(300, Math.round(v)));
  state.bpm = v;
  renderAll();
}

document.getElementById('bpmSlider').addEventListener('input', e => setBpm(+e.target.value));
document.getElementById('bpmInput').addEventListener('input', e => {
  const v = parseInt(e.target.value);
  if (!isNaN(v)) setBpm(v);
});
document.getElementById('bpmDown').addEventListener('click', () => setBpm(state.bpm - 1));
document.getElementById('bpmUp').addEventListener('click', () => setBpm(state.bpm + 1));

// Quick BPM
document.querySelectorAll('.bpm-btn').forEach(btn => {
  btn.addEventListener('click', () => setBpm(+btn.dataset.bpm));
});

// Tap tempo
const tapBtn = document.getElementById('tapBtn');
tapBtn.addEventListener('click', () => {
  const now = Date.now();
  tapTimes.push(now);
  if (tapTimeout) clearTimeout(tapTimeout);
  tapTimeout = setTimeout(() => { tapTimes = []; }, 2500);
  if (tapTimes.length > 8) tapTimes.shift();
  if (tapTimes.length >= 2) {
    const diffs = [];
    for (let i = 1; i < tapTimes.length; i++) diffs.push(tapTimes[i] - tapTimes[i-1]);
    const avg = diffs.reduce((a,b) => a+b, 0) / diffs.length;
    setBpm(Math.round(60000 / avg));
  }
  tapBtn.classList.add('tap-flash');
  setTimeout(() => tapBtn.classList.remove('tap-flash'), 120);
});

// Keyboard shortcut T = tap
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT') return;
  if (e.key === 't' || e.key === 'T') tapBtn.click();
  if (e.key === 'ArrowUp') setBpm(state.bpm + 1);
  if (e.key === 'ArrowDown') setBpm(state.bpm - 1);
});

// View switcher
window.setView = function(v) {
  state.view = v;
  document.querySelectorAll('.mode-tab').forEach((tab, i) => {
    tab.classList.toggle('active', ['all','natural','synthetic'][i] === v);
  });
  renderReverbGrid();
  updateValues();
};

// LED animation
setInterval(() => {
  const leds = ['led1','led2','led3','led4'];
  const idx = Math.floor(Math.random() * 4);
  const el = document.getElementById(leds[idx]);
  el.classList.toggle('active');
}, 600);

// ─── INIT ─────────────────────────────────────────────────────────────────────
renderNoteGrid();
renderReverbGrid();
renderAll();
</script>
</body>
</html>
