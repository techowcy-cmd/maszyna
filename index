<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>REVERB SYNC — BPM Calculator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&family=Barlow+Condensed:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg0: #0a0b0e;
    --bg1: #0f1117;
    --bg2: #141720;
    --bg3: #1c2030;
    --bg4: #232840;
    --panel: #181c2a;
    --panel2: #1e2336;
    --border: #2a3050;
    --border2: #3a4570;
    --accent: #00e5ff;
    --accent2: #7b5cf0;
    --accent3: #ff6b35;
    --accent4: #00ff9d;
    --accent5: #ff3b7a;
    --text: #e8eaf6;
    --text2: #8892b0;
    --text3: #4a5280;
    --led: #00e5ff;
    --led-off: #0a2030;
    --yellow: #ffd600;
    --orange: #ff9800;
    --green: #00ff9d;
    --red: #ff3b7a;
    --purple: #7b5cf0;
  }

  html { background: var(--bg0); }

  body {
    font-family: 'Rajdhani', sans-serif;
    background: var(--bg0);
    color: var(--text);
    min-height: 100vh;
    padding: 0;
    overflow-x: hidden;
  }

  /* Scanlines overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.07) 2px,
      rgba(0,0,0,0.07) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* Header */
  .header {
    background: var(--bg1);
    border-bottom: 1px solid var(--border);
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 34px; height: 34px;
    border: 1.5px solid var(--accent);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .logo-bars {
    display: flex; gap: 2px; align-items: flex-end; height: 18px;
  }

  .logo-bar {
    width: 3px;
    background: var(--accent);
    border-radius: 1px;
    animation: logoPulse 1.8s ease-in-out infinite;
  }
  .logo-bar:nth-child(1) { height: 6px; animation-delay: 0s; }
  .logo-bar:nth-child(2) { height: 14px; animation-delay: 0.2s; }
  .logo-bar:nth-child(3) { height: 10px; animation-delay: 0.4s; }
  .logo-bar:nth-child(4) { height: 18px; animation-delay: 0.1s; }
  .logo-bar:nth-child(5) { height: 8px; animation-delay: 0.3s; }

  @keyframes logoPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .logo-text {
    font-family: 'Share Tech Mono', monospace;
    font-size: 17px;
    letter-spacing: 3px;
    color: var(--accent);
    text-transform: uppercase;
  }

  .logo-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--text3);
    text-transform: uppercase;
    margin-top: -2px;
  }

  .header-right {
    display: flex; align-items: center; gap: 20px;
  }

  .led-group {
    display: flex; gap: 6px;
  }

  .led {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--led-off);
    transition: background 0.3s;
  }

  .led.active { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
  .led.active.g { background: var(--green); box-shadow: 0 0 6px var(--green); }
  .led.active.y { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); }

  /* Main Layout */
  .main {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 0;
    min-height: calc(100vh - 56px);
  }

  /* Left sidebar — BPM control */
  .sidebar {
    background: var(--bg1);
    border-right: 1px solid var(--border);
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .section-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--text3);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  /* BPM Big Display */
  .bpm-panel {
    background: var(--bg0);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px;
    text-align: center;
  }

  .bpm-display {
    font-family: 'Share Tech Mono', monospace;
    font-size: 64px;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -2px;
    text-shadow: 0 0 20px rgba(0,229,255,0.4);
    transition: all 0.15s;
    cursor: default;
    user-select: none;
  }

  .bpm-unit {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    letter-spacing: 5px;
    color: var(--text3);
    margin-top: 4px;
  }

  /* BPM Slider */
  .slider-wrap { margin: 4px 0; }

  input[type=range] {
    -webkit-appearance: none;
    width: 100%;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px rgba(0,229,255,0.6);
    border: 2px solid var(--bg0);
    cursor: grab;
    transition: transform 0.1s;
  }

  input[type=range]::-webkit-slider-thumb:active { transform: scale(1.2); cursor: grabbing; }
  input[type=range].accent2::-webkit-slider-thumb { background: var(--accent2); box-shadow: 0 0 8px rgba(123,92,240,0.6); }
  input[type=range].accent3::-webkit-slider-thumb { background: var(--accent3); box-shadow: 0 0 8px rgba(255,107,53,0.6); }

  .bpm-quick {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-top: 12px;
  }

  .bpm-btn {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text2);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 4px;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 1px;
  }

  .bpm-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(0,229,255,0.05); }
  .bpm-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(0,229,255,0.1); }

  /* Tap Tempo */
  .tap-btn {
    width: 100%;
    padding: 14px;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 6px;
    color: var(--text);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.1s;
    position: relative;
    overflow: hidden;
  }

  .tap-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,229,255,0.08);
    opacity: 0;
    transition: opacity 0.1s;
  }

  .tap-btn:active::after { opacity: 1; }
  .tap-btn:active { transform: scale(0.98); border-color: var(--accent); }

  .tap-flash { border-color: var(--accent) !important; box-shadow: 0 0 12px rgba(0,229,255,0.3) !important; }

  /* Note subdivision panel */
  .note-panel {
    background: var(--bg0);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px;
  }

  .note-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 5px;
  }

  .note-btn {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text2);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 7px 4px;
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    letter-spacing: 0.5px;
  }

  .note-btn:hover { border-color: var(--accent2); color: var(--accent2); }
  .note-btn.selected { border-color: var(--accent2); color: var(--accent2); background: rgba(123,92,240,0.12); }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 4px 0;
  }

  /* Time signature */
  .timesig-row {
    display: flex; gap: 8px; align-items: center;
  }

  .ts-select {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    padding: 8px 10px;
    outline: none;
    cursor: pointer;
    flex: 1;
  }

  .ts-select:focus { border-color: var(--accent); }

  /* Right area — reverb types grid */
  .content {
    background: var(--bg0);
    padding: 24px;
    overflow-y: auto;
  }

  .content-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }

  .content-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text);
  }

  /* Mode buttons */
  .mode-tabs {
    display: flex; gap: 4px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 4px;
  }

  .mode-tab {
    background: none;
    border: none;
    border-radius: 3px;
    color: var(--text3);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    padding: 6px 14px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .mode-tab.active { background: var(--bg4); color: var(--accent); }

  /* Reverb grid */
  .reverb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 14px;
  }

  /* Reverb card */
  .reverb-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s;
    position: relative;
  }

  .reverb-card:hover { border-color: var(--border2); }
  .reverb-card.featured { border-color: var(--accent2); }
  .reverb-card.featured .card-header { border-bottom-color: var(--accent2); }

  .card-header {
    padding: 14px 16px 12px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .card-type-badge {
    display: inline-block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 3px;
    border: 1px solid;
    margin-bottom: 6px;
  }

  .card-name {
    font-family: 'Rajdhani', sans-serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--text);
    line-height: 1;
  }

  .card-desc {
    font-size: 12px;
    color: var(--text3);
    margin-top: 4px;
    font-weight: 400;
    letter-spacing: 0.3px;
    line-height: 1.4;
  }

  .card-icon {
    width: 36px; height: 36px;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  /* Visualization bar */
  .decay-visual {
    padding: 10px 16px 0;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 36px;
  }

  .decay-bar {
    flex: 1;
    border-radius: 1px 1px 0 0;
    transition: height 0.4s cubic-bezier(0.4,0,0.2,1), opacity 0.4s;
    min-height: 2px;
  }

  /* Card body */
  .card-body {
    padding: 12px 16px 16px;
  }

  /* Value rows */
  .val-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid rgba(42,48,80,0.5);
  }

  .val-row:last-child { border-bottom: none; }

  .val-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    letter-spacing: 1px;
    color: var(--text3);
    text-transform: uppercase;
    font-weight: 500;
  }

  .val-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .val-numbers {
    display: flex; align-items: baseline; gap: 3px;
  }

  .val-main {
    font-family: 'Share Tech Mono', monospace;
    font-size: 18px;
    font-weight: 400;
    color: var(--text);
    transition: color 0.3s;
  }

  .val-unit {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    color: var(--text3);
    letter-spacing: 1px;
  }

  /* Sub values (musical notes) */
  .sub-vals {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid rgba(42,48,80,0.5);
  }

  .sub-val-chip {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 4px 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text3);
    display: flex;
    align-items: center;
    gap: 5px;
    transition: all 0.2s;
  }

  .sub-val-chip.highlight { border-color: currentColor; opacity: 1; }
  .sub-val-chip .chip-note {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 1px;
    opacity: 0.7;
  }

  /* Selected note highlight */
  .sub-val-chip.selected-note {
    background: rgba(0,229,255,0.08);
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Knob row */
  .knob-row {
    display: flex;
    gap: 12px;
    padding: 12px 16px;
    background: var(--bg0);
    border-top: 1px solid var(--border);
  }

  .knob-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
  }

  .knob {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 2px solid var(--border2);
    background: radial-gradient(circle at 40% 35%, #2a3050, #0f1117);
    position: relative;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .knob::after {
    content: '';
    position: absolute;
    top: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px; height: 10px;
    background: var(--text3);
    border-radius: 2px;
    transform-origin: bottom center;
  }

  .knob-val {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text3);
  }

  .knob-lbl {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--text3);
    text-transform: uppercase;
  }

  /* Waveform display */
  .waveform-container {
    padding: 0 16px 12px;
  }

  .waveform-canvas {
    width: 100%;
    height: 40px;
    border-radius: 3px;
    background: var(--bg0);
    border: 1px solid var(--border);
  }

  /* Color themes per type */
  .t-hall .card-type-badge { color: #7b5cf0; border-color: #7b5cf0; background: rgba(123,92,240,0.08); }
  .t-hall .val-dot { background: #7b5cf0; }
  .t-hall .val-main { color: #a584f5; }
  .t-hall .card-icon { background: rgba(123,92,240,0.12); color: #7b5cf0; }
  .t-hall .decay-bar { background: #7b5cf0; }
  .t-hall .sub-val-chip.selected-note { border-color: #7b5cf0; color: #7b5cf0; background: rgba(123,92,240,0.08); }

  .t-room .card-type-badge { color: #00e5ff; border-color: #00e5ff; background: rgba(0,229,255,0.07); }
  .t-room .val-dot { background: #00e5ff; }
  .t-room .val-main { color: #5ef0ff; }
  .t-room .card-icon { background: rgba(0,229,255,0.08); color: #00e5ff; }
  .t-room .decay-bar { background: #00e5ff; }
  .t-room .sub-val-chip.selected-note { border-color: #00e5ff; color: #00e5ff; background: rgba(0,229,255,0.07); }

  .t-plate .card-type-badge { color: #ff9800; border-color: #ff9800; background: rgba(255,152,0,0.08); }
  .t-plate .val-dot { background: #ff9800; }
  .t-plate .val-main { color: #ffb74d; }
  .t-plate .card-icon { background: rgba(255,152,0,0.1); color: #ff9800; }
  .t-plate .decay-bar { background: #ff9800; }
  .t-plate .sub-val-chip.selected-note { border-color: #ff9800; color: #ff9800; background: rgba(255,152,0,0.08); }

  .t-spring .card-type-badge { color: #00ff9d; border-color: #00ff9d; background: rgba(0,255,157,0.07); }
  .t-spring .val-dot { background: #00ff9d; }
  .t-spring .val-main { color: #4dffb8; }
  .t-spring .card-icon { background: rgba(0,255,157,0.08); color: #00ff9d; }
  .t-spring .decay-bar { background: #00ff9d; }
  .t-spring .sub-val-chip.selected-note { border-color: #00ff9d; color: #00ff9d; background: rgba(0,255,157,0.07); }

  .t-chamber .card-type-badge { color: #ff3b7a; border-color: #ff3b7a; background: rgba(255,59,122,0.07); }
  .t-chamber .val-dot { background: #ff3b7a; }
  .t-chamber .val-main { color: #ff7aaa; }
  .t-chamber .card-icon { background: rgba(255,59,122,0.08); color: #ff3b7a; }
  .t-chamber .decay-bar { background: #ff3b7a; }
  .t-chamber .sub-val-chip.selected-note { border-color: #ff3b7a; color: #ff3b7a; background: rgba(255,59,122,0.07); }

  .t-shimmer .card-type-badge { color: #ffd600; border-color: #ffd600; background: rgba(255,214,0,0.07); }
  .t-shimmer .val-dot { background: #ffd600; }
  .t-shimmer .val-main { color: #ffe066; }
  .t-shimmer .card-icon { background: rgba(255,214,0,0.08); color: #ffd600; }
  .t-shimmer .decay-bar { background: #ffd600; }
  .t-shimmer .sub-val-chip.selected-note { border-color: #ffd600; color: #ffd600; background: rgba(255,214,0,0.07); }

  .t-ambience .card-type-badge { color: #64b5f6; border-color: #64b5f6; background: rgba(100,181,246,0.07); }
  .t-ambience .val-dot { background: #64b5f6; }
  .t-ambience .val-main { color: #90caf9; }
  .t-ambience .card-icon { background: rgba(100,181,246,0.08); color: #64b5f6; }
  .t-ambience .decay-bar { background: #64b5f6; }
  .t-ambience .sub-val-chip.selected-note { border-color: #64b5f6; color: #64b5f6; background: rgba(100,181,246,0.07); }

  .t-nonlinear .card-type-badge { color: #ff6b35; border-color: #ff6b35; background: rgba(255,107,53,0.07); }
  .t-nonlinear .val-dot { background: #ff6b35; }
  .t-nonlinear .val-main { color: #ff9066; }
  .t-nonlinear .card-icon { background: rgba(255,107,53,0.08); color: #ff6b35; }
  .t-nonlinear .decay-bar { background: #ff6b35; }
  .t-nonlinear .sub-val-chip.selected-note { border-color: #ff6b35; color: #ff6b35; background: rgba(255,107,53,0.07); }

  .t-gated .card-type-badge { color: #b0bec5; border-color: #b0bec5; background: rgba(176,190,197,0.07); }
  .t-gated .val-dot { background: #b0bec5; }
  .t-gated .val-main { color: #cfd8dc; }
  .t-gated .card-icon { background: rgba(176,190,197,0.08); color: #b0bec5; }
  .t-gated .decay-bar { background: #b0bec5; }
  .t-gated .sub-val-chip.selected-note { border-color: #b0bec5; color: #b0bec5; background: rgba(176,190,197,0.07); }

  .t-cathedral .card-type-badge { color: #ce93d8; border-color: #ce93d8; background: rgba(206,147,216,0.07); }
  .t-cathedral .val-dot { background: #ce93d8; }
  .t-cathedral .val-main { color: #e1bee7; }
  .t-cathedral .card-icon { background: rgba(206,147,216,0.08); color: #ce93d8; }
  .t-cathedral .decay-bar { background: #ce93d8; }
  .t-cathedral .sub-val-chip.selected-note { border-color: #ce93d8; color: #ce93d8; background: rgba(206,147,216,0.07); }

